Matlab cobe for PID  
clc; clear; close all; 
% Time vector 
T = 0:1:300; 
dt = 1; 
% Setpoint and thresholds 
setpoint = 55; 
threshold_low = 50; 
threshold_high = 60; 
% PID Gains 
Kp = 2.5; 
Ki = 0.05; 
Kd = 1; 
% Ini aliza on 
moisture_noPID = zeros(1, length(T)); 
pump_noPID = zeros(1, length(T)); 
moisture_PID = zeros(1, length(T)); 
pump_PID = zeros(1, length(T)); 
moisture_noPID(1) = 35; 
moisture_PID(1) = 35; 
% Simulated environment data 
temperature = 25 + 3*sin(0.02*T); 
humidity = 60 + 10*sin(0.01*T + 1); 
26 
 
rain = rand(1, length(T)) < 0.01; 
rainMoisture = rain .* (5 + 5*rand(1, length(T))); 
% PID state 
integral = 0; 
prev_error = 0; 
% Main Simula on Loop 
for t = 2:length(T) 
    evap_loss = 0.03 + 0.005*(temperature(t) - 20) - 0.003*(humidity(t)/100); 
    % Without PID Control 
    if moisture_noPID(t-1) < setpoint && ~rain(t) 
        pumpPower_noPID = 100; 
    else 
        pumpPower_noPID = 0; 
    end 
    pump_noPID(t) = pumpPower_noPID; 
    pumpEffect_noPID = 0.2 * (pumpPower_noPID / 100); 
    moisture_noPID(t) = moisture_noPID(t-1) - evap_loss + pumpEffect_noPID + rainMoisture(t); 
    moisture_noPID(t) = max(0, min(100, moisture_noPID(t))); 
    % With PID Control 
    error = setpoint - moisture_PID(t-1); 
    integral = integral + error * dt; 
    deriva ve = (error - prev_error) / dt; 
    pid_output = Kp * error + Ki * integral + Kd * deriva ve; 
    if moisture_PID(t-1) < setpoint && ~rain(t) 
        pumpPower_PID = max(0, min(pid_output, 100)); 
    else 
        pumpPower_PID = 0; 
    end 
    pump_PID(t) = pumpPower_PID; 
    pumpEffect_PID = 0.2 * (pumpPower_PID / 100); 
    moisture_PID(t) = moisture_PID(t-1) - evap_loss + pumpEffect_PID + rainMoisture(t); 
    moisture_PID(t) = max(0, min(100, moisture_PID(t))); 
    prev_error = error; 
end 
